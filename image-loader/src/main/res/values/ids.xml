<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Stable View tag key used to associate the in-flight request URL with an ImageView.
        Using a resource ID prevents collisions with application-defined view tags.
    -->
    <item name="image_loader_request_tag" type="id" />
    <!--
        Stores the OnAttachStateChangeListener so it can be removed before a new one is
        added, preventing listener accumulation across RecyclerView rebinds.
    -->
    <item name="image_loader_lifecycle_tag" type="id" />
    <!--
        Collision-free per-view integer ID generated by an AtomicInteger counter.
        Replaces System.identityHashCode which is not guaranteed to be unique.
    -->
    <item name="image_loader_view_id_tag" type="id" />
    <!--
        Stores the OnLayoutChangeListener added when a request arrives before the view is
        measured (width/height == 0). Removed when a new request is enqueued, when the view
        detaches, or when the view is finally laid out and the real load starts.
    -->
    <item name="image_loader_layout_listener_tag" type="id" />
</resources>
